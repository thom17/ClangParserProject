# ClangParser Ignore File
# Similar to .gitignore, but for controlling which files to parse

# ============================================================
# Version Control Directories
# ============================================================
**/.git/**
**/.svn/**
**/.hg/**

# ============================================================
# Build Output Directories
# ============================================================
**/build/**
**/Build/**
**/BUILD/**
**/bin/**
**/Bin/**
**/obj/**
**/Obj/**
**/out/**
**/Out/**
**/dist/**
**/Debug/**
**/Release/**
**/RelWithDebInfo/**
**/MinSizeRel/**

# ============================================================
# CMake Build Files
# ============================================================
**/CMakeFiles/**
**/cmake-build-*/**

# ============================================================
# IDE Directories
# ============================================================
**/.vscode/**
**/.idea/**
**/.vs/**
**/.eclipse/**
**/.settings/**

# ============================================================
# Temporary and Cache Directories
# ============================================================
**/temp/**
**/tmp/**
**/cache/**
**/__pycache__/**
**/.cache/**

# ============================================================
# Third-Party Libraries (uncomment if needed)
# ============================================================
# **/third_party/**
# **/external/**
# **/vendor/**
# **/lib/**
# **/libs/**

# ============================================================
# Test Files (uncomment to exclude tests)
# ============================================================
# **/test/**
# **/tests/**
# **/*_test.cpp
# **/*_unittest.cpp
# **/*_test.h

# ============================================================
# Generated Files
# ============================================================
**/*.o
**/*.obj
**/*.a
**/*.lib
**/*.so
**/*.dll
**/*.dylib
**/*.exe
**/*.pyc
**/*.pyo
**/*.pyd

# ============================================================
# Backup and Temporary Files
# ============================================================
**/*~
**/*.bak
**/*.backup
**/*.swp
**/*.swo
**/*.tmp

# ============================================================
# Documentation Build Output
# ============================================================
**/docs/build/**
**/doc/html/**
**/_build/**

# ============================================================
# Package Manager Directories
# ============================================================
**/node_modules/**
**/bower_components/**

# ============================================================
# Include Patterns (patterns starting with ! are included)
# These override exclusions above
# ============================================================

# Include all C++ source files
!**/*.cpp
!**/*.cc
!**/*.cxx
!**/*.c++

# Include all C++ header files
!**/*.h
!**/*.hpp
!**/*.hxx
!**/*.h++
!**/*.hh

# Include C files
!**/*.c

# ============================================================
# Custom Patterns
# Add your project-specific patterns below
# ============================================================
